#!/usr/bin/env python3
from __future__ import annotations

import os
import signal
import subprocess
import sys
import threading


def main() -> int:
    args = sys.argv[1:]
    proc = subprocess.Popen(
        ['zsh', '-ic', 'acodex "$@"', '--', *args],
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )

    def terminate_child(signum: int, _frame: object) -> None:
        if proc.poll() is None:
            proc.terminate()

    signal.signal(signal.SIGTERM, terminate_child)
    signal.signal(signal.SIGINT, terminate_child)

    threads = [
        threading.Thread(target=copy_stdin, args=(proc,), daemon=True),
        threading.Thread(target=copy_stderr, args=(proc,), daemon=True),
        threading.Thread(target=copy_stdout, args=(proc, args[:1] == ['app-server']), daemon=True),
    ]
    for thread in threads:
        thread.start()
    return proc.wait()


def copy_stdin(proc: subprocess.Popen[bytes]) -> None:
    if proc.stdin is None:
        return
    try:
        while True:
            chunk = os.read(sys.stdin.fileno(), 65536)
            if not chunk:
                break
            proc.stdin.write(chunk)
            proc.stdin.flush()
    except (BrokenPipeError, OSError):
        pass
    finally:
        try:
            proc.stdin.close()
        except OSError:
            pass


def copy_stderr(proc: subprocess.Popen[bytes]) -> None:
    if proc.stderr is None:
        return
    for line in proc.stderr:
        sys.stderr.buffer.write(line)
        sys.stderr.buffer.flush()


def copy_stdout(proc: subprocess.Popen[bytes], json_rpc_only: bool) -> None:
    if proc.stdout is None:
        return
    for line in proc.stdout:
        if json_rpc_only and not line.lstrip().startswith(b'{'):
            sys.stderr.buffer.write(line)
            sys.stderr.buffer.flush()
            continue
        sys.stdout.buffer.write(line)
        sys.stdout.buffer.flush()


if __name__ == '__main__':
    raise SystemExit(main())
